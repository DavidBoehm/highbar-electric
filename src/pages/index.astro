---
import Layout from '../layouts/Layout.astro';
---

<Layout title="High-Bar Electric - Dependable Electrical Services">
  <!-- Hero Section -->
  <section class="relative min-h-[calc(100vh-5rem)] flex items-center justify-center bg-gradient-to-br from-gray-900 via-gray-800 to-black text-white overflow-hidden -mt-20 pt-20">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%239C92AC" fill-opacity="0.1"%3E%3Cpath d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
    </div>
    
    <div class="container mx-auto px-6 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-red-500 font-semibold text-lg mb-4 tracking-wide uppercase">Trusted by industry experts</p>
        <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">
          Dependable Electrical<br/>
          <span class="text-red-500 animate-pulse-slow">Built on Experience</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-3xl mx-auto">
          Delivering dependable, high-quality electrical solutions built on experience, technical expertise, and integrity—ensuring every project is completed safely, efficiently, and to the highest standard.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#contact" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-4 px-8 rounded-lg transition-all transform hover:scale-105 shadow-lg">
            Call Now
          </a>
          <a href="#services" class="border-2 border-white hover:bg-white hover:text-gray-900 text-white font-semibold py-4 px-8 rounded-lg transition-all">
            Our Services
          </a>
        </div>
      </div>
    </div>
    
    <!-- Stats -->
    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent">
      <div class="container mx-auto px-6 py-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          <div class="stat-card relative p-6 rounded-xl bg-gray-800/50 backdrop-blur-sm">
            <div class="text-4xl md:text-5xl font-bold text-red-500 mb-2">5.0</div>
            <p class="text-gray-400">Rating</p>
          </div>
          <div class="stat-card relative p-6 rounded-xl bg-gray-800/50 backdrop-blur-sm">
            <div class="text-4xl md:text-5xl font-bold text-red-500 mb-2">20+</div>
            <p class="text-gray-400">Years of Experience</p>
          </div>
          <div class="stat-card relative p-6 rounded-xl bg-gray-800/50 backdrop-blur-sm">
            <div class="text-4xl md:text-5xl font-bold text-red-500 mb-2">100%</div>
            <p class="text-gray-400">Quality</p>
          </div>
          <div class="stat-card relative p-6 rounded-xl bg-gray-800/50 backdrop-blur-sm">
            <div class="text-4xl md:text-5xl font-bold text-red-500 mb-2">500+</div>
            <p class="text-gray-400">Projects Completed</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-24 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Discover All the Services we Provide</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Clear, reliable electrical solutions for commercial and residential projects—delivered safely, efficiently, and to code.
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Service 1 -->
        <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-2xl transition-shadow border-t-4 border-red-600">
          <div class="w-16 h-16 bg-red-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Testing & Diagnostics</h3>
          <p class="text-gray-600 leading-relaxed">
            Specialized electrical testing including megger testing, voltage monitoring, and system evaluations to support troubleshooting, compliance, and engineering review.
          </p>
        </div>
        
        <!-- Service 2 -->
        <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-2xl transition-shadow border-t-4 border-red-600">
          <div class="w-16 h-16 bg-red-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Commercial Electrical</h3>
          <p class="text-gray-600 leading-relaxed">
            Tenant improvements, power distribution, lighting upgrades, switchgear, and ongoing maintenance for offices, retail, medical, and multi-unit properties.
          </p>
        </div>
        
        <!-- Service 3 -->
        <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-2xl transition-shadow border-t-4 border-red-600">
          <div class="w-16 h-16 bg-red-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Residential Electrical</h3>
          <p class="text-gray-600 leading-relaxed">
            Service upgrades, lighting, panel work, repairs, and electrical improvements designed for safety, comfort, and long-term reliability in your home.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Section -->
  <section class="py-24 bg-gray-900 text-white">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold mb-6">Where Trust and Dependability meet</h2>
        <p class="text-xl text-gray-300 mb-8">
          Licensed, insured, and experienced electrical services focused on safety, clear communication, and results that last. Serving Denver & Colorado Springs greater area.
        </p>
        <div class="flex flex-wrap justify-center gap-8 text-sm text-gray-400">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Licensed & Insured
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            24/7 Emergency Service
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Denver & Colorado Springs
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-24 bg-red-600 text-white">
    <div class="container mx-auto px-6 text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-6">Ready to Get Started?</h2>
      <p class="text-xl mb-8 max-w-2xl mx-auto">
        Contact Scott Skiles today for a free estimate on your electrical project. Serving the greater Denver & Colorado Springs area.
      </p>
      <a href="tel:+15551234567" class="inline-block bg-white text-red-600 font-bold py-4 px-12 rounded-lg hover:bg-gray-100 transition-colors text-lg">
        Call (555) 123-4567
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-950 text-gray-400 py-12">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-4 gap-8 mb-8">
        <div>
          <h3 class="text-white text-xl font-bold mb-4">High-Bar Electric</h3>
          <p class="mb-4">Serving Denver & Colorado Springs with dependable electrical solutions built on experience.</p>
          <p class="text-sm text-gray-500">Owner/Operator: Scott Skiles</p>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-4">Services</h4>
          <ul class="space-y-2">
            <li><a href="#" class="hover:text-red-500 transition-colors">Testing & Diagnostics</a></li>
            <li><a href="#" class="hover:text-red-500 transition-colors">Commercial Electrical</a></li>
            <li><a href="#" class="hover:text-red-500 transition-colors">Residential Electrical</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-4">Contact</h4>
          <p>Phone: (555) 123-4567</p>
          <p>Email: info@highbarelectric.com</p>
          <p class="mt-2 text-sm">Denver & Colorado Springs</p>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-4">Follow Us</h4>
          <div class="flex gap-4">
            <a href="https://www.yelp.com/biz/high-bar-electric-parker" target="_blank" rel="noopener" class="hover:text-red-500 transition-colors">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 5.523 4.477 10 10 10s10-4.477 10-10c0-5.523-4.477-10-10-10zm4.5 14.5c0 .828-.672 1.5-1.5 1.5h-1c-.828 0-1.5-.672-1.5-1.5v-4c0-.828.672-1.5 1.5-1.5h1c.828 0 1.5.672 1.5 1.5v4zm-4 0c0 .828-.672 1.5-1.5 1.5h-1c-.828 0-1.5-.672-1.5-1.5v-7c0-.828.672-1.5 1.5-1.5h1c.828 0 1.5.672 1.5 1.5v7zm-4 0c0 .828-.672 1.5-1.5 1.5h-1c-.828 0-1.5-.672-1.5-1.5v-5c0-.828.672-1.5 1.5-1.5h1c.828 0 1.5.672 1.5 1.5v5z"/></svg>
            </a>
            <a href="https://www.facebook.com/p/High-Bar-Electric-61552956202194/" target="_blank" rel="noopener" class="hover:text-red-500 transition-colors">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          </div>
        </div>
      </div>
      <div class="border-t border-gray-800 pt-8 text-center">
        <p>&copy; {new Date().getFullYear()} High-Bar Electric. All rights reserved. Owner/Operator: Scott Skiles</p>
      </div>
    </div>
    <!-- SEO: Hidden Buildzoom reference -->
    <div class="hidden" aria-hidden="true">
      <a href="https://www.buildzoom.com/contractor/high-bar-electric-llc-parker-co" rel="nofollow">Buildzoom Profile</a>
    </div>
  </footer>
</Layout>
