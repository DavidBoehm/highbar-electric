---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Get a Quote - High-Bar Electric">
  <!-- Hero Section -->
  <section class="relative py-24 bg-gradient-to-br from-gray-900 via-gray-800 to-black text-white">
    <div class="container mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-6xl font-bold mb-6">Get a Quote</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Transparent pricing for commercial and residential electrical services in Denver & Colorado Springs.
      </p>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-24 bg-gray-50">
    <div class="container mx-auto px-6 max-w-4xl">
      
      <!-- Free Estimate -->
      <div class="bg-white rounded-2xl shadow-xl p-8 md:p-12 mb-8 border-l-4 border-green-500">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center">
            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-gray-900">Free Phone Estimate</h2>
            <p class="text-green-600 font-semibold text-lg">$0</p>
          </div>
        </div>
        <p class="text-gray-600 text-lg">
          Scott Skiles offers free estimates over the phone. Call now to discuss your project and get a preliminary quote with no obligation.
        </p>
      </div>

      <!-- Residential Rate -->
      <div class="bg-white rounded-2xl shadow-xl p-8 md:p-12 mb-8 border-l-4 border-red-500">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-14 h-14 bg-red-100 rounded-full flex items-center justify-center">
            <svg class="w-7 h-7 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-gray-900">Residential Diagnostics</h2>
            <p class="text-red-600 font-semibold text-lg">Starting at $100/hour</p>
          </div>
        </div>
        <p class="text-gray-600 text-lg mb-4">
          In-person troubleshooting and diagnostics for residential electrical systems.
        </p>
        <ul class="space-y-2 text-gray-600">
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Complete system evaluation
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Detailed troubleshooting report
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Upfront repair recommendations
          </li>
        </ul>
      </div>

      <!-- Commercial Rate -->
      <div class="bg-white rounded-2xl shadow-xl p-8 md:p-12 mb-8 border-l-4 border-red-600">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-14 h-14 bg-red-600/20 rounded-full flex items-center justify-center">
            <svg class="w-7 h-7 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-gray-900">Commercial Diagnostics</h2>
            <p class="text-red-600 font-semibold text-lg">Starting at $200/hour</p>
          </div>
        </div>
        <p class="text-gray-600 text-lg mb-4">
          In-person troubleshooting and diagnostics for commercial and industrial electrical systems.
        </p>
        <ul class="space-y-2 text-gray-600">
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Industrial-grade testing equipment
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            PLC, VFD, and control system diagnostics
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Code compliance assessment
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Project scope and timeline estimates
          </li>
        </ul>
      </div>

      <!-- CTA -->
      <div class="text-center">
        <p class="text-gray-600 mb-6">Ready to get started? Call Scott Skiles for your free estimate.</p>
        <a href="tel:+15551234567" class="inline-block bg-red-600 hover:bg-red-700 text-white font-bold py-4 px-12 rounded-lg transition-colors text-lg">
          Call (555) 123-4567
        </a>
      </div>

    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-950 text-gray-400 py-12">
    <div class="container mx-auto px-6 text-center">
      <p>&copy; {new Date().getFullYear()} High-Bar Electric. All rights reserved. Owner/Operator: Scott Skiles</p>
    </div>
  </footer>
</Layout>
