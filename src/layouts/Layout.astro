---
export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="High-Bar Electric - Dependable electrical services built on experience. Serving Colorado with residential and commercial solutions." />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		<style is:global>
			@import "../styles/global.css";
			body {
				font-family: 'Manrope', system-ui, sans-serif;
			}
		</style>
	</head>
	<body class="antialiased">
		<!-- Navigation -->
		<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm transition-all duration-300" id="navbar">
			<div class="container mx-auto px-6">
				<div class="flex items-center justify-between h-20">
					<!-- Logo -->
					<a href="/" class="flex items-center gap-2 group">
						<div class="w-10 h-10 bg-red-600 rounded-lg flex items-center justify-center transition-transform group-hover:scale-110">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
							</svg>
						</div>
						<span class="text-xl font-bold text-gray-900">High-Bar<span class="text-red-600">Electric</span></span>
					</a>
					
					<!-- Desktop Navigation -->
					<div class="hidden md:flex items-center gap-8">
						<a href="/" class="text-gray-700 hover:text-red-600 font-medium transition-colors">Home</a>
						<a href="/#services" class="text-gray-700 hover:text-red-600 font-medium transition-colors">Services</a>
						<a href="/quote" class="text-gray-700 hover:text-red-600 font-medium transition-colors">Get a Quote</a>
						<a href="/quote" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2.5 px-6 rounded-lg transition-all hover:shadow-lg">Contact Us</a>
					</div>
					
					<!-- Mobile Menu Button -->
					<button class="md:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors" id="mobile-menu-btn" aria-label="Toggle menu">
						<svg class="w-6 h-6 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="menu-icon">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
						</svg>
						<svg class="w-6 h-6 text-gray-900 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="close-icon">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
						</svg>
					</button>
				</div>
				
				<!-- Mobile Navigation -->
				<div class="md:hidden hidden bg-white border-t border-gray-100" id="mobile-menu">
					<div class="py-4 space-y-2">
						<a href="/" class="block py-3 px-4 text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded-lg font-medium transition-colors">Home</a>
						<a href="/#services" class="block py-3 px-4 text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded-lg font-medium transition-colors">Services</a>
						<a href="/quote" class="block py-3 px-4 text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded-lg font-medium transition-colors">Get a Quote</a>
						<a href="/quote" class="block py-3 px-4 text-red-600 font-semibold hover:bg-red-50 rounded-lg transition-colors">Contact Us</a>
					</div>
				</div>
			</div>
		</nav>
		
		<!-- Spacer for fixed navbar -->
		<div class="h-20"></div>
		
		<slot />
		
		<script>
			// Mobile menu toggle
			const mobileMenuBtn = document.getElementById('mobile-menu-btn');
			const mobileMenu = document.getElementById('mobile-menu');
			const menuIcon = document.getElementById('menu-icon');
			const closeIcon = document.getElementById('close-icon');
			
			mobileMenuBtn?.addEventListener('click', () => {
				mobileMenu?.classList.toggle('hidden');
				menuIcon?.classList.toggle('hidden');
				closeIcon?.classList.toggle('hidden');
			});
			
			// Close mobile menu when clicking a link
			mobileMenu?.querySelectorAll('a').forEach(link => {
				link.addEventListener('click', () => {
					mobileMenu?.classList.add('hidden');
					menuIcon?.classList.remove('hidden');
					closeIcon?.classList.add('hidden');
				});
			});
			
			// Navbar scroll effect
			const navbar = document.getElementById('navbar');
			let lastScroll = 0;
			
			window.addEventListener('scroll', () => {
				const currentScroll = window.pageYOffset;
				
				if (currentScroll > 50) {
					navbar?.classList.add('shadow-md');
				} else {
					navbar?.classList.remove('shadow-md');
				}
				
				lastScroll = currentScroll;
			});
		</script>
	</body>
</html>
